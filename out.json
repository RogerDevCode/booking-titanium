      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nconst service_id = String(body.service_id || 'google_calendar');\nconst action = String(body.action || 'check');\nconst error_message = body.error_message || null;\nconst metadata = body.metadata || {};\n\nconst SERVICE_ID_RE = /^[a-zA-Z0-9_-]{1,100}$/;\nif (!SERVICE_ID_RE.test(service_id)) {\n  throw new Error('Invalid service_id: must be alphanumeric/underscore/hyphen, max 100 chars');\n}\n\nconst VALID_ACTIONS = ['check', 'record_success', 'record_failure'];\nif (!VALID_ACTIONS.includes(action)) {\n  throw new Error('Invalid action: ' + action);\n}\n\nconst safe_error = error_message\n  ? String(error_message).substring(0, 500)\n  : null;\n\nreturn [{ json: { service_id, action, error_message: safe_error, metadata } }];",
          "notice": ""
        },
