    {
      "parameters": {
        "jsCode": "const input = $input.first().json.body || $input.first().json;\n\n// VRF — GUARD + VALIDATE\nconst isValidUUID = (v) => /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(v);\nconst bookingId = input.old_booking_id || input.booking_id;\n\nif (!bookingId || !isValidUUID(bookingId)) {\n  throw new Error('Invalid or missing booking_id (UUID required)');\n}\nif (!input.new_start_time) {\n  throw new Error('Missing required field: new_start_time');\n}\n\nreturn [{\n  json: {\n    chat_id: parseInt(input.chat_id) || null,\n    booking_id: bookingId,\n    old_booking_id: bookingId,\n    new_start_time: input.new_start_time,\n    provider_id: parseInt(input.provider_id) || 1,\n    service_id: parseInt(input.service_id) || 1,\n    user_email: input.user_email || '',\n    user_name: input.user_name || 'Paciente'\n  }\n}];"
      },
      "name": "Build Secure JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        50,
        432
      ],
      "id": "a73cdab7-d391-409c-80ad-a5450c90f1b5"
    },
    {
