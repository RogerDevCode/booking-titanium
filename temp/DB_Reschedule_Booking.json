        },
        "mode": "wait",
        "inputData": "={{ $json }}",
        "options": {}
      },
      "name": "Step 1: Cancel Old",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [
        300,
        432
      ],
      "id": "00a11762-fa76-4dc6-bff2-de484002fec8"
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "ilA6a6sM5CvDsSBi",
          "mode": "id"
        },
        "mode": "wait",
        "inputData": "={\n  \"chat_id\": {{ $node[\"Build Secure JSON\"].json.chat_id }},\n  \"start_time\": \"{{ $node[\"Build Secure JSON\"].json.new_start_time }}\",\n  \"provider_id\": {{ $node[\"Build Secure JSON\"].json.provider_id }},\n  \"service_id\": {{ $node[\"Build Secure JSON\"].json.service_id }},\n  \"user_email\": \"{{ $node[\"Build Secure JSON\"].json.user_email }}\",\n  \"user_name\": \"{{ $node[\"Build Secure JSON\"].json.user_name }}\"\n}",
        "options": {}
      },
      "name": "Step 2: Create New",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [
        550,
        432
      ],
      "id": "922e30dc-a5bd-462a-9c35-b277fe60aa59"
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      old_booking_id: $node[\"Build Secure JSON\"]?.json?.old_booking_id || $node[\"Build Secure JSON\"]?.json?.booking_id,\n      new_booking_id: $node[\"Step 2: Create New\"]?.json?.data?.booking_id || $node[\"Step 2: Create New\"]?.json?.booking_id || null\n    },\n    _meta: { source: \"DB_Reschedule_Booking\", timestamp: new Date().toISOString() }\n  }\n}];"
      },
