    {
      "parameters": {
        "jsCode": "/*\n  Format Error Payload — isolates 4 sources into common format.\n  - Error Trigger: { execution, workflow }\n  - Webhook / Execute / Manual: manual payload\n*/\nconst incoming = $input.first()?.json || {};\nconst isSystemError = !!incoming.execution;\nconst payload = isSystemError ? incoming : incoming.body || incoming;\n\nreturn {\n  workflow_id: payload.workflow?.id || \"UNKNOWN\",\n  workflow_name: payload.workflow?.name || \"UNKNOWN\",\n  execution_id: payload.execution?.id || \"MANUAL_TEST_ID\",\n  error_message: payload.execution?.error?.message || payload.error_message || \"Unknown Error\",\n  error_stack: payload.execution?.error?.stack || \"\",\n  last_node: payload.execution?.lastNodeExecuted || \"\",\n  mode: payload.execution?.mode || \"manual\"\n};"
      },
      "name": "Format Error Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        432
      ],
      "id": "12041585-ed88-4d8c-a1fd-ad644bbaf715"
    },
    {
      "parameters": {
        "jsCode": "// VRF — Build Safe SQL (SEC_02: escape backslash + single quote + length limit)\nconst esc = (v) => String(v || '').replace(/\\\\/g, '\\\\\\\\').replace(/'/g, \"''\").substring(0, 500);\nconst data = $input.first()?.json || {};\n\nconst wfName = esc(data.workflow_name);\nconst execId = esc(data.execution_id);\nconst errMsg = esc(data.error_message);\nconst details = esc(JSON.stringify(data));\n\nreturn [{\n  json: {\n    query: `INSERT INTO system_logs (workflow_name, execution_id, level, message, details) VALUES ('${wfName}', '${execId}', 'ERROR', '${errMsg}', '${details}') RETURNING id;`,\n    ...data\n  }\n}];"
      },
      "name": "Build Safe SQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        432
      ],
      "id": "bdfd215b-ed1e-42bf-a2b8-3046797f324a"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $node[\"Build Safe SQL\"].json.query }}",
        "options": {}
      },
      "name": "Log to Postgres",
