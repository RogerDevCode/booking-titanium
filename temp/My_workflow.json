      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst chat_id = Number(item.chat_id);\nconst text = String(item.text || \"\").trim();\n\nif(!chat_id || text.length < 2){\n return [{json:{valid:false}}]\n}\n\nreturn [{json:{valid:true,chat_id,text}}]"
      },
