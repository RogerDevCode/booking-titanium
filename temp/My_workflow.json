    {
      "parameters": {
        "jsCode": "const text=$json.text;\n\nconst blocked=[\"ignore previous instructions\",\"system prompt\",\"reveal tools\"];\n\nfor(const b of blocked){\n if(text.toLowerCase().includes(b)){\n  return [{json:{blocked:true,text}}]\n }\n}\n\nreturn [{json:{blocked:false,...$json}}]"
      },
