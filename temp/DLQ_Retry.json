    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT booking_dlq_resolve($1::bigint, 'auto_retry', 'Successfully retried via DLQ');",
        "options": {
          "queryReplacement": "={{ $json.id }}"
        }
      },
      "name": "Mark Resolved",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1250,
