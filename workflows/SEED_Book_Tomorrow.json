        "jsCode": "const today = new Date();\nconst tomorrow = new Date(today);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\nconst dateStr = tomorrow.toISOString().split('T')[0];\nconst slots = ['09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00'];\n\nreturn slots.map((time, i) => ({\n  json: {\n    provider_id: 1,\n    service_id: 1,\n    start_time: `${dateStr}T${time}:00.000-03:00`,\n    duration_minutes: 60,\n    chat_id: `980000${i}`,\n    customer_id: `seed-cust-${i}`,\n    user_name: `Seed Patient ${String.fromCharCode(65 + i)}`,\n    user_email: `seed${i}@test.local`,\n    event_title: `[SEED] Booking - Patient ${String.fromCharCode(65 + i)}`\n  }\n}));"
      },
      "id": "build_config",
      "name": "Build Seed Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 100]
    },
