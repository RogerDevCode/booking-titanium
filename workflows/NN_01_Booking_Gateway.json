    {
      "parameters": {
        "jsCode": "// REGLA 1: NORMALIZACIÓN DE TIPOS\n// Extraer respetando la estructura de Telegram\nconst input = $input.first()?.json || {};\nconst bodyLayer = input.body || input;\nconst message = bodyLayer.message || bodyLayer.channel_post || bodyLayer;\n\nconst chat_id = message.chat?.id || bodyLayer.chat_id || input.chat_id || 0;\nconst text = message.text || bodyLayer.text || input.text || \"\";\n\nconst isValid = Boolean(chat_id && text);\n\nreturn [{\n  json: {\n    isValid,\n    ...input,\n    chat_id: Number(chat_id),\n    text: String(text).trim()\n  }\n}];"
      },
