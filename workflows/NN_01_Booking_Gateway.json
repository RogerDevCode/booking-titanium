    {
      "parameters": {
        "jsCode": "// Error response for invalid input\nconst inputData = $input.first()?.json || {};\n\nreturn [{\n  json: {\n    success: false,\n    error_code: inputData.error_code || \"INVALID_INPUT\",\n    error_message: inputData.error_message || \"Invalid Telegram payload\",\n    data: null,\n    _meta: {\n      source: \"NN_01_Booking_Gateway\",\n      timestamp: new Date().toISOString(),\n      workflow_id: \"NN_01\",\n      version: \"1.0.0\"\n    }\n  }\n}];"
      },
