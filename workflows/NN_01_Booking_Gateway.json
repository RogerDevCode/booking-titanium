    {
      "parameters": {
        "jsCode": "const nn02 = $node[\"Parse Incoming Payload (NN_02)\"]?.json || {};\nconst ai = $node[\"Execute AI Agent (NN_03)\"]?.json || {};\nconst tg = $node[\"Send Telegram Response (NN_04)\"]?.json || {};\n\n/* NN_04 returns Standard Contract: {success, data:{message_id}} */\nconst tgOk = !!(tg.success || tg.data?.message_id);\nconst isSuccess = !!(nn02.success && ai.success && tgOk);\n\nlet errCode = null;\nlet errMsg = null;\nif (!nn02.success) { errCode = nn02.error_code || 'VALIDATION_ERROR'; errMsg = nn02.error_message; }\nelse if (!ai.success) { errCode = ai.error_code || 'AI_ERROR'; errMsg = ai.error_message; }\nelse if (!tgOk) { errCode = tg.error_code || 'TELEGRAM_API_ERROR'; errMsg = tg.error_message || 'Telegram failed to send message'; }\n\nreturn [{ json: {\n  success: isSuccess,\n  error_code: isSuccess ? null : errCode,\n  error_message: isSuccess ? null : errMsg,\n  data: isSuccess ? {\n    message_sent: true,\n    chat_id: ai.data?.chat_id || nn02.data?.chat_id,\n    ai_response: ai.data?.ai_response,\n    intent: ai.data?.intent\n  } : null,\n  _meta: { source: 'NN_01_Booking_Gateway', workflow_id: 'NN_01', timestamp: new Date().toISOString(), version: '4.2.0' }\n} }];"
      },
