    },
    {
      "parameters": {
        "jsCode": "// Error response for NN_02 failure\nconst nn02_error = $input.first()?.json?.nn02_error || $input.first()?.json || {};\n\nreturn [{\n  json: {\n    success: false,\n    error_code: nn02_error.error_code || \"NN02_ERROR\",\n    error_message: nn02_error.error_message || \"NN_02 processing failed\",\n    data: null,\n    _meta: nn02_error._meta || {\n      source: \"NN_01_Booking_Gateway\",\n      timestamp: new Date().toISOString(),\n      workflow_id: \"NN_01\",\n      version: \"1.0.0\"\n    }\n  }\n}];"
      },
