      "parameters": {
        "jsCode": "// Error response for NN_04 failure\nconst nn04_error = $input.first()?.json || {};\n\nreturn [{\n  json: {\n    success: false,\n    error_code: nn04_error.error_code || \"NN04_ERROR\",\n    error_message: nn04_error.error_message || \"NN_04 Telegram sending failed\",\n    data: null,\n    _meta: {\n      source: \"NN_01_Booking_Gateway\",\n      timestamp: new Date().toISOString(),\n      workflow_id: \"NN_01\",\n      version: \"1.0.0\"\n    }\n  }\n}];"
      },
      "name": "Format NN_04 Error",
