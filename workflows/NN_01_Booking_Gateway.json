        608
      ],
      "id": "exec_trigger"
    },
    {
      "parameters": {
        "jsCode": "// Get raw input from webhook\n// n8n Webhook passes data in $json, often inside 'body' if it's production\nconst inputItem = $input.first()?.json || {};\nconst rawInput = inputItem.body || inputItem;\n\n// Check if this looks like a Telegram message\nconst message = rawInput.message || rawInput.channel_post || {};\nconst chat_id = message.chat?.id;\nconst text = message.text;\n\n// If no message structure found, this is an invalid payload\nif (!chat_id || !text) {\n  return [{\n    json: {\n      isValid: false,\n      error_code: \"INVALID_PAYLOAD\",\n      error_message: \"Missing chat_id or text in Telegram payload\",\n      debug_received: inputItem\n    }\n  }];\n}\n\n// Valid payload - pass to NN_02\nreturn [{\n  json: {\n    isValid: true,\n    raw_input: rawInput\n  }\n}];"
      },
      "name": "Validate Input (PRE)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        432
      ],
      "id": "validate_input"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "rightValue": ""
          },
          "conditions": [
            {
              "id": "cond_grrpyp",
              "leftValue": "={{ $json.isValid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Is Valid Input?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        800,
        432
      ],
      "id": "if_valid"
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "Hp7ox7JqRwVA5wr8",
          "mode": "id"
        },
        "mode": "wait",
        "options": {
          "waitForSubworkflow": true,
          "mode": "passthrough"
        },
        "inputSource": "passthrough"
      },
      "name": "Execute NN_02",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [
        1000,
        432
      ],
      "id": "exec_nn02",
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Check NN_02 response\nconst nn02 = $input.first()?.json || {};\n\nif (nn02.success === true && nn02.data) {\n  return [{\n    json: {\n      nn02_success: true,\n      nn02_data: nn02.data,\n      nn02_meta: nn02._meta\n    }\n  }];\n} else {\n  return [{\n    json: {\n      nn02_success: false,\n      nn02_error: nn02\n    }\n  }];\n}"
      },
      "name": "Check NN_02 Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
