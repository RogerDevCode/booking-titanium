    {
      "parameters": {
        "jsCode": "// Error response for NN_03 failure\nconst nn03_error = $input.first()?.json?.nn03_error || $input.first()?.json || {};\n\nreturn [{\n  json: {\n    success: false,\n    error_code: nn03_error.error_code || \"NN03_ERROR\",\n    error_message: nn03_error.error_message || \"NN_03 AI processing failed\",\n    data: null,\n    _meta: nn03_error._meta || {\n      source: \"NN_01_Booking_Gateway\",\n      timestamp: new Date().toISOString(),\n      workflow_id: \"NN_01\",\n      version: \"1.0.0\"\n    }\n  }\n}];"
      },
      "name": "Format NN_03 Error",
