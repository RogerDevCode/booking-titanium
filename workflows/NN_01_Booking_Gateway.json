    {
      "parameters": {
        "jsCode": "// Check NN_03 response\nconst nn03 = $input.first()?.json || {};\n\nif (nn03.success === true && nn03.data?.ai_response) {\n  return [{\n    json: {\n      nn03_success: true,\n      ai_response: nn03.data.ai_response,\n      chat_id: nn03.data.chat_id\n    }\n  }];\n} else {\n  return [{\n    json: {\n      nn03_success: false,\n      nn03_error: nn03\n    }\n  }];\n}"
      },
