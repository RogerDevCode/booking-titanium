    {
      "parameters": {
        "jsCode": "const result = $input.first()?.json || {};\nconst isError = !!result.error;\n\nreturn [{\n  json: {\n    success: !isError,\n    error_code: isError ? 'GCAL_DELETE_ERROR' : null,\n    error_message: isError ? (result.error?.message || 'Failed to delete GCal event') : null,\n    data: isError ? null : { deleted: true },\n    _meta: {\n      source: 'GCAL_Delete_Event',\n      timestamp: new Date().toISOString(),\n      workflow_id: 'GCAL_Delete_Event',\n      version: '1.1.0'\n    }\n  }\n}];"
      },
