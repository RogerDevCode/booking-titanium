    {
      "parameters": {
        "jsCode": "// Handle DAL HTTP error\nconst e = $input.first().json;\nconst upstreamData = $('Validate Input').isExecuted ? $('Validate Input').first().json : {};\nlet error_code = 'DAL_ERROR';\nlet error_message = e.message || 'DAL service unavailable';\n\nif (e.statusCode === 429) {\n  error_code = 'RATE_LIMITED';\n  error_message = 'Too many requests';\n} else if (e.statusCode >= 500) {\n  error_code = 'DAL_SERVER_ERROR';\n  error_message = 'DAL service internal error';\n} else if (e.statusCode === 408 || e.message.includes('timeout')) {\n  error_code = 'DAL_TIMEOUT';\n  error_message = 'DAL service timeout';\n}\n\nreturn [{ json: {\n  ...upstreamData,\n  success: false, error_code, error_message, data: null,\n  _meta: { source: 'DB_Find_Next_Available', timestamp: new Date().toISOString(), workflow_id: $workflow.id }\n}}];",
        "mode": "runOnceForAllItems"
