      "parameters": {
        "jsCode": "// LAYER 1+2: Extract & Validate (§4.1 PRE-validate)\n// Zero-throw: returns Standard Contract error, never throws\n\nconst raw = $input.first().json;\nconst input = (raw.body && typeof raw.body === 'object') ? raw.body : raw;\n\nfunction ve(code, msg) {\n  return [{ json: {\n    success: false, error_code: code, error_message: msg, data: null,\n    _meta: { source: 'DB_Find_Next_Available', timestamp: new Date().toISOString(), workflow_id: $workflow.id },\n    _exit_early: true\n  }}];\n}\n\n// === PROVIDER_ID VALIDATION ===\nlet provider_id;\nif (input.provider_id === undefined || input.provider_id === null) {\n  return ve('MISSING_FIELD', 'provider_id is required');\n}\nif (typeof input.provider_id === 'string') {\n  const trimmed = input.provider_id.trim();\n  const INT_RE = /^\\d+$/;\n  if (!INT_RE.test(trimmed)) return ve('INVALID_TYPE', 'provider_id must be a positive integer');\n  provider_id = parseInt(trimmed);\n} else if (typeof input.provider_id === 'number') {\n  provider_id = input.provider_id;\n  if (!Number.isInteger(provider_id) || provider_id < 1) return ve('INVALID_TYPE', 'provider_id must be a positive integer');\n} else {\n  return ve('INVALID_TYPE', 'provider_id must be a number or numeric string');\n}\n\n// === SERVICE_ID VALIDATION ===\nlet service_id;\nif (input.service_id === undefined || input.service_id === null) {\n  return ve('MISSING_FIELD', 'service_id is required');\n}\nif (typeof input.service_id === 'string') {\n  const trimmed = input.service_id.trim();\n  const INT_RE = /^\\d+$/;\n  if (!INT_RE.test(trimmed)) return ve('INVALID_TYPE', 'service_id must be a positive integer');\n  service_id = parseInt(trimmed);\n} else if (typeof input.service_id === 'number') {\n  service_id = input.service_id;\n  if (!Number.isInteger(service_id) || service_id < 1) return ve('INVALID_TYPE', 'service_id must be a positive integer');\n} else {\n  return ve('INVALID_TYPE', 'service_id must be a number or numeric string');\n}\n\n// === DATE VALIDATION ===\nlet date;\nif (input.date === undefined || input.date === null) {\n  return ve('MISSING_FIELD', 'date is required (YYYY-MM-DD format)');\n}\ndate = String(input.date).trim();\n\n// Validate YYYY-MM-DD format\nconst DATE_RE = /^\\d{4}-\\d{2}-\\d{2}$/;\nif (!DATE_RE.test(date)) return ve('INVALID_TYPE', 'date must be in YYYY-MM-DD format');\n\n// Validate date exists (not Feb 30, etc.)\nconst dateObj = new Date(date + 'T00:00:00Z');\nif (isNaN(dateObj.getTime())) return ve('INVALID_DATE', 'date is not a valid calendar date');\n\n// Check date components match (catches Feb 30 → Mar 02 normalization)\nconst [year, month, day] = date.split('-').map(Number);\nif (dateObj.getUTCFullYear() !== year || (dateObj.getUTCMonth() + 1) !== month || dateObj.getUTCDate() !== day) {\n  return ve('INVALID_DATE', 'date does not exist in the calendar');\n}\n\nreturn [{ json: {\n  success: true,\n  provider_id,\n  service_id,\n  date,\n  _validated: true\n}}];",
        "mode": "runOnceForAllItems"
      },
