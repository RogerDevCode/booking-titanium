  "name": "DLQ_02_Get_Status",
  "description": null,
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "path": "dlq/status",
        "httpMethod": "GET",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "webhookId": "dlq-status",
      "id": "c5e44a17-f1d0-48e2-a7c6-47eb963af792"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(status, 'empty') as status, COUNT(*) as count\nFROM booking_dlq\nGROUP BY status\nUNION ALL\nSELECT 'total' as status, COUNT(*) as count FROM booking_dlq\nHAVING COUNT(*) = 0;",
        "options": {}
      },
      "name": "Get DB Stats",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "credentials": {
        "postgres": {
          "id": "5LzvCP9BsQwCi9Z0",
          "name": "Postgres account"
        }
      },
      "id": "5ade372f-a469-4287-81ef-d932861429f6"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst stats = {\n  pending: 0,\n  resolved: 0,\n  discarded: 0,\n  total: 0\n};\n\nrows.forEach(row => {\n  const s = row.json.status;\n  const c = parseInt(row.json.count);\n  if (stats.hasOwnProperty(s)) stats[s] = c;\n  stats.total += c;\n});\n\nreturn [{\n  json: {\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      pending_count: stats.pending,\n      resolved_count: stats.resolved,\n      discarded_count: stats.discarded,\n      total_items: stats.total\n    },\n    _meta: {\n      source: 'DLQ_02_Get_Status',\n      timestamp: new Date().toISOString(),\n      workflow_id: $workflow.id\n    }\n  }\n}];"
      },
      "name": "Format Status Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "id": "d4b6fd20-b1e9-4091-90c9-752517db4ad3"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
