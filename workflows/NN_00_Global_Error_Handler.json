        {
            "parameters": {
                "jsCode": "/*\n  Aislamos las 4 fuentes en un formato comun.\n  - `Error Trigger` trae data en `{ execution, workflow }`\n  - `Webhook / Execute / Manual` traen un payload manual similar.\n*/\nconst incoming = $input.first()?.json || {};\nconst isSystemError = !!incoming.execution;\n\n// Mapeamos el payload\nconst payload = isSystemError ? incoming : incoming.body || incoming;\n\nreturn {\n  workflow_id: payload.workflow?.id || \"UNKNOWN\",\n  workflow_name: payload.workflow?.name || \"UNKNOWN\",\n  execution_id: payload.execution?.id || \"MANUAL_TEST_ID\",\n  error_message: payload.execution?.error?.message || payload.error_message || \"Unknown Error\",\n  error_stack: payload.execution?.error?.stack || \"\",\n  last_node: payload.execution?.lastNodeExecuted || \"\",\n  mode: payload.execution?.mode || \"manual\"\n};"
            },
            "name": "Format Error Payload",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                480,
                432
            ],
            "id": "7701a661-e61d-4404-b64f-cb7e98839c51"
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "INSERT INTO system_logs (workflow_name, execution_id, level, message, details) VALUES ('{{ $json.workflow_name }}', '{{ $json.execution_id }}', 'ERROR', '{{ $json.error_message.replace(/'/g, \"''\") }}', '{{ JSON.stringify($json).replace(/'/g, \"''\") }}') RETURNING id;",
                "options": {}
            },
            "name": "Log to Postgres",
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.6,
