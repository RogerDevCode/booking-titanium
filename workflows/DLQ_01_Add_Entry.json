      "parameters": {},
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "id": "b5df008a-68b6-4eb9-800d-0f78a60ae987"
    },
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "id": "0653a9ec-2ead-46f4-844d-155a0886bcd2"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nconst payload = {\n  booking_id: parseInt(body.booking_id) || null,\n  provider_id: parseInt(body.provider_id) || null,\n  service_id: parseInt(body.service_id) || 1,\n  failure_reason: String(body.failure_reason || 'UNKNOWN').substring(0, 100),\n  error_message: String(body.error_message || 'No message provided').substring(0, 500),\n  error_stack: body.error_stack ? String(body.error_stack).substring(0, 2000) : null,\n  original_payload: body.original_payload || {},\n  idempotency_key: body.idempotency_key || 'gen_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)\n};\n\nconst b64Payload = Buffer.from(JSON.stringify(payload)).toString('base64');\nreturn [{ json: { b64_payload: b64Payload, ...payload } }];\n"
      },
      "name": "Validate & Encode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "id": "b2c9c185-d8a6-4103-9275-449168f93907"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM booking_dlq_add(convert_from(decode($1, 'base64'), 'utf-8')::jsonb);",
        "options": {
          "queryReplacement": "={{ $json.b64_payload }}"
        }
      },
      "name": "Insert to DLQ",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "credentials": {
        "postgres": {
          "id": "5LzvCP9BsQwCi9Z0",
          "name": "Postgres account"
        }
      },
      "id": "52e68a58-a8eb-4791-a71f-10c5d07abbf2"
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst validated = $('Validate & Encode').first().json;\n\nreturn [{\n  json: {\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      dlq_id: result.out_dlq_id,\n      idempotency_key: validated.idempotency_key\n    },\n    _meta: {\n      source: 'DLQ_01_Add_Entry',\n      timestamp: new Date().toISOString(),\n      workflow_id: $workflow.id\n    }\n  }\n}];"
      },
      "name": "Standard Contract Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
