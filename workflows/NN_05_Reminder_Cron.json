{
  "name": "NN_05_Reminder_Cron",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        0,
        432
      ],
      "id": "cron"
    },
    {
      "parameters": {},
      "name": "When clicking 'Test workflow'",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        232
      ],
      "id": "manual"
    },
    {
      "parameters": {
        "url": "http://dal-service:3000/pending-reminders",
        "options": {}
      },
      "name": "Fetch Pending",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        250,
        432
      ],
      "id": "fetch"
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "name": "Split Bookings",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        500,
        432
      ],
      "id": "split"
    },
    {
      "parameters": {
        "jsCode": "// Prepare Reminder — maps dal-service booking to NN_04 payload\nconst item = $input.first()?.json || {};\n\nconst chat_id = String(item.user_id || '');\nconst service = item.service_name || 'Cita';\nconst provider = item.provider_name || 'Profesional';\nconst startRaw = item.start_time || '';\nconst reminder_type = parseInt(item.reminder_type) || 1;\n\n// Format time for display\nlet timeDisplay = startRaw;\ntry {\n  const d = new Date(startRaw);\n  timeDisplay = d.toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' });\n} catch(e) {}\n\nconst text = `\u23f0 Recordatorio: Tienes una cita de ${service} con ${provider} \u2014 ${timeDisplay}`;\n\nreturn [{\n  json: {\n    chat_id,\n    text,\n    booking_id: item.id || '',\n    reminder_type\n  }\n}];"
      },
      "name": "Prepare Reminder",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        432
      ],
      "id": "prepare"
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "WE7DxLKAECtsA8Up",
          "mode": "id"
        },
        "options": {}
      },
      "name": "Notify Telegram",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [
        1000,
        432
      ],
      "id": "exec_tg"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://dal-service:3000/mark-reminder-sent",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"booking_id\": \"{{ $node[\"Prepare Reminder\"].json.booking_id }}\",\n  \"type\": {{ $node[\"Prepare Reminder\"].json.reminder_type }}\n}",
        "options": {}
      },
      "name": "Mark as Sent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1250,
        432
      ],
      "id": "mark"
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      reminders_sent: $node[\"Split Bookings\"].json ? 1 : 0\n    },\n    _meta: {\n      source: \"NN_05_Reminder_Cron\",\n      timestamp: new Date().toISOString(),\n      workflow_id: \"NN_05\",\n      version: \"1.1.0\"\n    }\n  }\n}];"
      },
      "name": "Format Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        432
      ],
      "id": "format_out"
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Fetch Pending",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "When clicking 'Test workflow'": {
      "main": [
        [
          {
