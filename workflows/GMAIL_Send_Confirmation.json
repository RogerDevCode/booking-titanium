{
  "name": "GMAIL_Send_Confirmation",
  "nodes": [
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        400
      ],
      "id": "trigger_unique"
    },
    {
      "parameters": {},
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        200
      ],
      "id": "manual"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gmail-send-confirmation",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        600
      ],
      "webhookId": "gmail-send-confirmation",
      "id": "webhook"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.user_email || $json.final_email || 'baba.orere@gmail.com' }}",
        "subject": "📅 Reserva Confirmada - Booking Titanium",
        "message": "=Hola,\n\nTu cita ha sido agendada.\n\nFecha: {{ $json.start_time }}\n\nGracias.",
        "appendAttributions": false
      },
      "name": "Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [
        350,
        432
      ],
      "id": "gmail_node",
      "credentials": {
        "gmailOAuth2": {
          "id": "2oXMGEYDP70ILkBs",
          "name": "Gmail account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const gmailResponse = $input.first()?.json || {};\nconst isError = !!gmailResponse.error;\n\nreturn [{\n  json: {\n    success: !isError,\n    error_code: isError ? 'GMAIL_ERROR' : null,\n    error_message: isError ? (gmailResponse.error?.message || 'Gmail send failed') : null,\n    data: isError ? null : {\n      message_id: gmailResponse.id || null,\n      thread_id: gmailResponse.threadId || null\n    },\n    _meta: {\n      source: 'GMAIL_Send_Confirmation',\n      timestamp: new Date().toISOString(),\n      workflow_id: 'GMAIL_Send_Confirmation',\n      version: '1.1.0'\n    }\n  }\n}];"
      },
      "name": "Format Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        432
      ],
      "id": "format_out"
    },
    {
      "parameters": {
        "jsCode": "/* VRF PRE: Validate */\nconst item = $input.first()?.json || {};\nconst data = item.body || item;\nconst isValid = true; // Auto-generated default\nreturn [{ json: { isValid, ...data } }];"
      },
      "id": "validate_pre_auto",
      "name": "Validate PRE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "valid_cond_auto",
              "leftValue": "={{ $json.isValid === true }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if_valid_auto",
      "name": "Is Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        200,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// 📤 STANDARD CONTRACT OUTPUT (O02)\n// Retorna esquema unificado para todos los workflows\n\nconst result = $input.first()?.json || {};\n\nreturn [{\n  json: {\n    success: result.success !== false,\n    error_code: result.success === false ? (result.error_code || 'UNKNOWN_ERROR') : null,\n    error_message: result.success === false ? (result.error_message || 'An error occurred') : null,\n    data: result.data || null,\n    _meta: {\n      source: 'GMAIL_SEND_CONFIRMATION',\n      workflow_id: 'GMAIL_SEND_CONFIRMATION',\n      timestamp: new Date().toISOString(),\n      version: '4.3.1'\n    }\n  }\n}];"
      },
      "id": "standard_contract_1772984456920",
      "name": "📤 Standard Contract Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5000,
        500
      ]
    }
  ],
  "connections": {
