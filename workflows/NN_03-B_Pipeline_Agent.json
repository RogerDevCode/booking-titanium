    {
      "parameters": {
        "jsCode": "const content = $json.text || '';\nconst jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\nlet params = {};\nif (jsonMatch) {\n  try { params = JSON.parse(jsonMatch[0]); } catch(e) {}\n}\n\nparams.chat_id = $('Type Normalization').first().json.chat_id || 0;\n\nconst uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst bookingId = String(params.booking_id || '');\n\nif (!uuidRegex.test(bookingId)) {\n  return [{\n    json: {\n      success: false,\n      error_code: 'INVALID_BOOKING_ID',\n      error_message: 'No se encontró un ID de reserva válido (UUID) en tu mensaje. Por favor indica tu código de reserva.'\n    }\n  }];\n}\n\nparams.booking_id = bookingId;\nreturn [{ json: params }];"
