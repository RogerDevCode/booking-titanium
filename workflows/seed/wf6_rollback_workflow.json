      "webhookId": "rollback-booking"
    },
    {
      "parameters": {
        "jsCode": "// Rollback Input Validator - FASE 1.3\n// Input: { booking_id, gcal_event_id?, lock_id?, lock_key?, reason? }\n\nconst input = $input.first().json;\n\nconst hasBookingId = !!input.booking_id;\nconst hasGcalEventId = !!input.gcal_event_id;\nconst hasLockId = !!input.lock_id;\nconst hasLockKey = !!input.lock_key;\n\nif (!hasBookingId && !hasGcalEventId && !hasLockId && !hasLockKey) {\n  throw new Error('Rollback requires at least one ID');\n}\n\nconst steps = [];\nif (hasGcalEventId) steps.push('gcal');\nif (hasBookingId) steps.push('db');\nif (hasLockId || hasLockKey) steps.push('lock');\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      steps: steps,\n      reason: input.reason || 'manual_rollback',\n      initiated_at: new Date().toISOString()\n    },\n    gcal_event_id: input.gcal_event_id || null,\n    booking_id: input.booking_id || null,\n    lock_id: input.lock_id || null,\n    lock_key: input.lock_key || null\n  }\n}];"
      },
      "name": "Validate Rollback Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value": "={{ $json.gcal_event_id }}",
              "operation": "notEmpty"
            }
          ]
        }
      },
      "name": "Has GCal Event?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        500,
        0
      ]
    },
    {
      "parameters": {
        "operation": "delete",
        "calendar": {
          "__rl": true,
          "value": "dev.n8n.stax@gmail.com",
          "mode": "list",
          "cachedResultName": "dev.n8n.stax@gmail.com"
        },
        "eventId": "={{ $json.gcal_event_id }}",
        "options": {}
      },
      "name": "Delete GCal Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        750,
        -100
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "NDk9hJZ9MTokyiAh",
          "name": "Google Calendar account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// GCal deletion result\nconst gcal = $input.first().json;\nconst input = $('Validate Rollback Input').first().json;\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      ...input._rollback,\n      gcal_deleted: true,\n      gcal_deleted_at: new Date().toISOString()\n    }\n  }\n}];"
      },
      "name": "GCal Deleted Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        -100
      ]
    },
    {
      "parameters": {
        "jsCode": "// GCal skip result\nconst input = $input.first().json;\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      ...input._rollback,\n      gcal_skipped: true,\n      gcal_skip_reason: 'no_event_id'\n    }\n  }\n}];"
      },
      "name": "GCal Skip Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        100
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value": "={{ $json.booking_id }}",
              "operation": "notEmpty"
            }
          ]
        }
      },
      "name": "Has DB Booking?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1000,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE bookings SET status = 'cancelled', cancelled_at = NOW(), cancellation_reason = $1::text WHERE booking_id = $2::int RETURNING booking_id, status;",
        "options": {
          "queryReplacement": "={{ $json._rollback.reason || 'rollback' }}, {{ $json.booking_id }}"
        }
      },
      "name": "Soft Delete DB Booking",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1250,
        -100
      ],
      "credentials": {
        "postgres": {
          "id": "SFNQsmuu4zirZAnP",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// DB cancellation result\nconst db = $input.first().json;\nconst input = $('Validate Rollback Input').first().json;\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      ...input._rollback,\n      db_cancelled: true,\n      db_cancelled_at: new Date().toISOString(),\n      db_booking_id: db.booking_id\n    }\n  }\n}];"
      },
