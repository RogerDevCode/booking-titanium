      "typeVersion": 2.3,
      "position": [
        1500,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM booking_locks WHERE lock_id = $1::int OR lock_key = $2::text RETURNING lock_id;",
        "options": {
          "queryReplacement": "={{ $json.lock_id ?? 0 }}, {{ $json.lock_key ?? '' }}"
        }
      },
      "name": "Release Lock",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1750,
        -100
      ],
      "credentials": {
        "postgres": {
          "id": "SFNQsmuu4zirZAnP",
          "name": "Postgres account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Lock released result\nconst lock = $input.first().json;\nconst input = $('Validate Rollback Input').first().json;\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      ...input._rollback,\n      lock_released: true,\n      lock_released_at: new Date().toISOString(),\n      lock_id: lock.lock_id\n    }\n  }\n}];"
      },
      "name": "Lock Released Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        -100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Lock skip result\nconst input = $input.first().json;\n\nreturn [{\n  json: {\n    ...input,\n    _rollback: {\n      ...input._rollback,\n      lock_skipped: true,\n      lock_skip_reason: 'no_lock_id_or_key'\n    }\n  }\n}];"
      },
      "name": "Lock Skip Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Standard Contract Output - Rollback Complete\nconst input = $input.first().json;\nconst rb = input._rollback;\n\nreturn [{\n  json: {\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      rollback_completed: true,\n      reason: rb.reason,\n      steps_executed: {\n        gcal_delete: rb.gcal_deleted === true,\n        db_cancel: rb.db_cancelled === true,\n        lock_release: rb.lock_released === true\n      },\n      steps_skipped: {\n        gcal: rb.gcal_skipped === true,\n        db: rb.db_skipped === true,\n        lock: rb.lock_skipped === true\n      },\n      initiated_at: rb.initiated_at,\n      completed_at: new Date().toISOString()\n    },\n    _meta: {\n      source: 'WF6_ROLLBACK_WORKFLOW',\n      timestamp: new Date().toISOString(),\n      version: '1.1.0'\n    }\n  }\n}];"
      },
      "name": "Standard Contract Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2250,
        0
      ]
    }
  ],
