{
  "name": "WF6_Rollback_Workflow",
  "nodes": [
    {
      "parameters": {
        "path": "rollback-booking",
        "httpMethod": "POST",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "webhookId": "rollback-booking"
    },
    {
      "parameters": {},
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        -200
      ]
    },
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nconst UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\n\nlet booking_id = body.booking_id || null;\nif (booking_id && !UUID_RE.test(booking_id)) {\n  // If not a UUID, ignore it to prevent SQL error, or throw.\n  // For robustness, let's just set it to null if invalid format.\n  booking_id = null;\n}\n\nconst payload = {\n  gcal_event_id: body.gcal_event_id || null,\n  booking_id: booking_id,\n  lock_key: body.lock_key || null,\n  owner_token: body.owner_token || null,\n  reason: String(body.reason || 'manual_rollback').substring(0, 500)\n};\n\nif (!payload.gcal_event_id && !payload.booking_id && !payload.lock_key) {\n  throw new Error('Rollback requires at least one valid ID (gcal, booking uuid or lock)');\n}\n\nconst b64Reason = Buffer.from(payload.reason).toString('base64');\n\nreturn [{ json: {\n  ...payload,\n  b64_reason: b64Reason,\n  _rollback: {\n    initiated_at: new Date().toISOString(),\n    steps: { gcal: { success: true, skipped: true }, db: { success: true, skipped: true }, lock: { success: true, skipped: true } }\n  }\n}}];"
      },
      "name": "Validate & Prepare",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has_gcal",
              "leftValue": "={{ $json.gcal_event_id }}",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Has GCal?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        500,
        0
      ]
    },
    {
      "parameters": {
        "operation": "delete",
        "calendar": {
          "__rl": true,
          "value": "primary",
          "mode": "list"
        },
        "eventId": "={{ $json.gcal_event_id }}"
      },
      "name": "Delete GCal",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        750,
        -100
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "NDk9hJZ9MTokyiAh",
          "name": "Google Calendar account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prev = $('Validate & Prepare').first().json;\nconst isError = !!input.message;\n// 404 is acceptable (idempotency)\nconst is404 = isError && (input.message.includes('404') || input.message.toLowerCase().includes('not found'));\n\nreturn [{ json: {\n  ...prev,\n  _rollback: {\n    ...prev._rollback,\n    steps: { ...prev._rollback.steps, gcal: { success: !isError || is404, skipped: false, error: isError && !is404 ? input.message : null } }\n  }\n}}];"
      },
      "name": "Post GCal",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has_db",
              "leftValue": "={{ $json.booking_id }}",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Has DB?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1250,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE bookings SET status = 'CANCELLED', cancelled_at = NOW(), cancellation_reason = convert_from(decode($1, 'base64'), 'utf-8') WHERE id = $2::uuid AND status != 'CANCELLED' RETURNING id;",
        "options": {
          "queryReplacement": "={{ $json.b64_reason }}, {{ $json.booking_id }}"
        }
      },
      "name": "Cancel DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1500,
        -100
      ],
      "credentials": {
        "postgres": {
          "id": "SFNQsmuu4zirZAnP",
          "name": "Postgres account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prev = $('Post GCal').first().json;\nconst isError = !!input.message;\nreturn [{ json: {\n  ...prev,\n  _rollback: {\n    ...prev._rollback,\n    steps: { ...prev._rollback.steps, db: { success: !isError, skipped: false, was_updated: !!input.id, error: isError ? input.message : null } }\n  }\n}}];"
      },
      "name": "Post DB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has_lock",
              "leftValue": "={{ $json.lock_key }}",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Has Lock?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        2000,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM booking_locks WHERE lock_key = $1::text AND owner_token = $2::text RETURNING lock_id;",
        "options": {
          "queryReplacement": "={{ $json.lock_key }}, {{ $json.owner_token }}"
        }
      },
      "name": "Release Lock",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        2250,
        -100
      ],
      "credentials": {
        "postgres": {
          "id": "SFNQsmuu4zirZAnP",
          "name": "Postgres account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prev = $('Post DB').first().json;\nconst isError = !!input.message;\nreturn [{ json: {\n  ...prev,\n  _rollback: {\n    ...prev._rollback,\n    steps: { ...prev._rollback.steps, lock: { success: !isError, skipped: false, was_released: !!input.lock_id, error: isError ? input.message : null } }\n  }\n}}];"
      },
      "name": "Post Lock",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2500,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const rb = $input.first().json._rollback;\nconst steps = rb.steps;\nconst hasFailure = !steps.gcal.success || !steps.db.success || !steps.lock.success;\n\nreturn [{ json: {\n  success: !hasFailure,\n  error_code: hasFailure ? 'PARTIAL_ROLLBACK_FAILED' : null,\n  error_message: hasFailure ? 'Some rollback steps failed' : null,\n  data: {\n    rollback_completed: !hasFailure,\n    steps: steps,\n    initiated_at: rb.initiated_at,\n    completed_at: new Date().toISOString()\n  },\n  _meta: { source: 'WF6_Rollback_Workflow', timestamp: new Date().toISOString(), workflow_id: $workflow.id }\n}}];"
      },
      "name": "Standard Contract Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2750,
        0
      ]
    }
