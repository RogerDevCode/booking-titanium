{
  "name": "WF2_Booking_Orchestrator",
  "nodes": [
    {
      "id": "77ce45e4-7ac9-427e-adbf-475880d66370",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        -1008,
        112
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "booking-orchestrator",
        "responseMode": "lastNode",
        "options": {
          "allowedMethods": [
            "POST"
          ]
        }
      },
      "webhookId": "booking-orchestrator"
    },
    {
      "id": "afba31a8-777c-43b3-b60f-0e124ad76d47",
      "name": "Generate Idempotency Key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -752,
        112
      ],
      "parameters": {
        "jsCode": "// Idempotency Check v2.0 - Context Preservation Pattern\nconst rawInput = $input.first().json;\nconst input = rawInput.body || rawInput;\n\n// Validación de input requerido (SEC02 - PRE validation)\nconst required = ['provider_id', 'service_id', 'start_time'];\nfor (const field of required) {\n  if (!input[field]) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\n// Generar idempotency_key determinístico\nconst idempotencyKey = `booking_${input.provider_id}_${input.service_id}_${input.start_time}_${input.customer_id || input.chat_id || 'anonymous'}`;\n\n// Sanitizar string (SEC05)\nconst sanitizedKey = idempotencyKey\n  .replace(/[^a-zA-Z0-9_:-]/g, '_')\n  .substring(0, 255);\n\n// Construir contexto único que viajará por todo el workflow\nconst ctx = {\n  // Datos originales de input\n  provider_id: input.provider_id,\n  service_id: input.service_id,\n  start_time: input.start_time,\n  end_time: input.end_time || null,\n  customer_id: input.customer_id || null,\n  chat_id: input.chat_id || null,\n  user_id: input.user_id || null,\n  \n  // Idempotency\n  idempotency_key: sanitizedKey,\n  \n  // Metadata\n  _idempotency: {\n    key: sanitizedKey,\n    created_at: new Date().toISOString()\n  },\n  _meta: {\n    source: 'WF2_BOOKING_ORCHESTRATOR',\n    version: '2.0.0',\n    started_at: new Date().toISOString()\n  }\n};\n\nreturn [{ json: { ctx } }];"
      }
    },
    {
      "id": "8407a32f-09b1-48f4-8b2a-030ad20c10ae",
      "name": "Check Idempotency DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -496,
        112
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT b.id as booking_id, b.status, b.gcal_event_id FROM (SELECT 1) dummy LEFT JOIN bookings b ON b.idempotency_key = $1::text AND b.status != 'CANCELLED' LIMIT 1;",
        "options": {
          "queryReplacement": "={{ $json.ctx.idempotency_key }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "5LzvCP9BsQwCi9Z0",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "899458e8-72b3-4ddb-b5b1-a7ab9c39853a",
      "name": "Is Duplicate?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -256,
        112
      ],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value": "={{ Array.isArray($json) && $json.length > 0 && !!$json[0]?.id }}",
              "operation": "true"
            }
          ],
          "conditions": [
            {
              "id": "is_dup",
              "leftValue": "={{ $json._is_duplicate }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "00ab33b4-e6e2-435f-9026-cad0a17ef025",
      "name": "Return Duplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        208
      ],
      "parameters": {
        "jsCode": "// DUPLICATE BRANCH - Return existing booking\nconst existing = $input.first().json[0] || $input.first().json;\nconst ctx = $input.first().json.ctx || {};\n\n// Preservar contexto completo incluso en rama de duplicado\nctx._idempotency.is_duplicate = true;\nctx._idempotency.existing_booking_id = existing.id;\n\nreturn [{\n  json: {\n    ctx,\n    success: true,\n    error_code: null,\n    error_message: null,\n    data: {\n      booking_id: existing.id,\n      status: existing.status,\n      gcal_event_id: existing.gcal_event_id,\n      is_duplicate: true,\n      message: 'Booking already exists (idempotent retry)'\n    },\n    _meta: {\n      source: 'WF2_BOOKING_ORCHESTRATOR',\n      timestamp: new Date().toISOString(),\n      version: '2.0.0',\n      idempotency: 'duplicate'\n    }\n  }\n}];"
      }
    },
    {
      "id": "6eaacd95-3ef4-4c2f-9f71-932cb0426ae8",
      "name": "Merge Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "jsCode": "// MERGE CONTEXT - After Is Duplicate? (false branch)\n// Este nodo asegura que el contexto viaje intacto por la rama de no-duplicado\nconst ctx = $input.first().json.ctx;\n\n// Agregar flag de que es una nueva reserva (no duplicada)\nctx._idempotency.is_duplicate = false;\n\nreturn [{ json: { ctx } }];"
      }
    },
    {
      "id": "183d1702-7945-4e67-82a5-0834196acd10",
