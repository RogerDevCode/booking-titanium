      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO bookings (provider_id, service_id, start_time, end_time, idempotency_key, gcal_event_id, user_id, status, created_at) VALUES ($1::int, $2::int, $3::timestamp, ($3::timestamp + INTERVAL '1 hour'), $4::text, $5::text, $6::bigint, 'CONFIRMED', NOW()) RETURNING id;",
        "options": {
          "queryReplacement": "={{ $json.ctx.provider_id }}, {{ $json.ctx.service_id }}, {{ $json.ctx.start_time }}, {{ $json.ctx.idempotency_key }}, {{ $json.id || $json.eventId }}, {{ $json.ctx.user_id || $json.ctx.chat_id }}"
        }
      },
      "credentials": {
