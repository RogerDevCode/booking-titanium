    {
      "id": "470292c8-5c71-4fc7-a8cb-51a00253d256",
      "name": "Error - No Availability",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        112
      ],
      "parameters": {
        "jsCode": "// NOT AVAILABLE BRANCH - Preserve context and return error\nconst ctx = $input.first().json.ctx;\nconst availabilityResult = $input.first().json;\n\nctx._meta.failed_at = 'Check Availability';\n\nreturn [{\n  json: {\n    ctx,\n    success: false,\n    error_code: 'NO_AVAILABILITY',\n    error_message: 'No availability found for requested time slot',\n    data: null,\n    _meta: {\n      source: 'WF2_BOOKING_ORCHESTRATOR',\n      timestamp: new Date().toISOString(),\n      version: '2.0.0'\n    }\n  }\n}];"
      }
    },
