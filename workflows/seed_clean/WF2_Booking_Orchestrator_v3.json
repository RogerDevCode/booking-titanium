    },
    {
      "parameters": {
        "jsCode": "// LOCK DENIED - Slot already booked\nconst ctx = $input.first().json.ctx;\nctx._meta.failed_at = 'Acquire Lock';\n\nreturn [{\n  json: {\n    ctx,\n    success: false,\n    error_code: 'LOCK_DENIED',\n    error_message: 'Slot already booked by another user',\n    data: null,\n    _meta: {\n      source: 'WF2_BOOKING_ORCHESTRATOR_V3',\n      timestamp: new Date().toISOString(),\n      version: '3.0.0-internal'\n    }\n  }\n}];"
      },
      "name": "Error - Lock Denied",
