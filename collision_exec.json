      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "const events = $input.all();\nconst validated = $('Validate & Prepare').first().json;\n\n// Paranoia: Si el nodo anterior falló (error en API de Google)\nif (events.length > 0 && events[0].json.message && !events[0].json.id) {\n  return [{ json: { _gcal_error: events[0].json.message, _success: false } }];\n}\n\nconst reqStart = new Date(validated.start_time).getTime();\nconst reqEnd = new Date(validated.end_time).getTime();\nconst excludeId = validated.exclude_event_id;\n\nconst conflicts = events.filter(item => {\n  const ev = item.json;\n  if (!ev.id || ev.status === 'cancelled' || ev.id === excludeId) return false;\n\n  // Handle date (all-day) vs dateTime (specific time)\n  const evStart = new Date(ev.start.dateTime || ev.start.date).getTime();\n  const evEnd = new Date(ev.end.dateTime || ev.end.date).getTime();\n\n  // Atomic overlap check: (StartA < EndB) AND (EndA > StartB)\n  return reqStart < evEnd && reqEnd > evStart;\n}).map(c => ({\n  id: c.json.id,\n  summary: c.json.summary,\n  start: c.json.start.dateTime || c.json.start.date\n}));\n\nreturn [{ json: {\n  _success: true,\n  has_collision: conflicts.length > 0,\n  conflicts: conflicts\n}}];",
          "notice": ""
        },
