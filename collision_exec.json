          "language": "javaScript",
          "jsCode": "const result = $input.first().json;\nconst isValidationError = !$('Is Valid?').isExecuted || $('Is Valid?').first(1)?.json?._valid === false;\n\nif (isValidationError) {\n  return [{ json: {\n    success: false, error_code: 'VALIDATION_ERROR', \n    error_message: $('Validate & Prepare').first().json._error,\n    data: null, _meta: { source: 'WF5_Collision_Check', timestamp: new Date().toISOString(), workflow_id: $workflow.id }\n  }}];\n}\n\nif (result._success === false) {\n  return [{ json: {\n    success: true,\n    error_code: 'GCAL_ERROR',\n    error_message: 'Google Calendar API error: ' + result._gcal_error,\n    data: { slot_available: false, mode: 'fail_closed', error: result._gcal_error },\n    _meta: { source: 'WF5_Collision_Check', timestamp: new Date().toISOString(), workflow_id: $workflow.id }\n  }}];\n}\n\nreturn [{ json: {\n  success: true,\n  error_code: null,\n  error_message: null,\n  data: {\n    slot_available: !result.has_collision,\n    has_collision: result.has_collision,\n    conflicts: result.conflicts,\n    checked_at: new Date().toISOString()\n  },\n  _meta: { source: 'WF5_Collision_Check', timestamp: new Date().toISOString(), workflow_id: $workflow.id }\n}}];",
