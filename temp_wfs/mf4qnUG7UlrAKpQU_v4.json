            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "description": "Cancela una reserva existente.",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": true
  }
}
