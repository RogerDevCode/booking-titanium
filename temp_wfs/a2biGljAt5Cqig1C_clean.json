      ],
      "id": "a127848f-8329-481f-868c-1e5e233a8cc7"
    },
    {
      "parameters": {},
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        200
      ],
      "id": "8d8bca67-1448-453c-ab9d-82b50aa77906"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gcal-delete-event",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        600
      ],
      "webhookId": "gcal-delete-event",
      "id": "0a7d7706-8573-4563-ae32-fa41b27197b4"
    },
    {
      "parameters": {
        "calendar": "primary",
        "operation": "delete",
        "eventId": "={{ $json.gcal_event_id || $json.body?.gcal_event_id }}"
      },
      "name": "Delete GCal Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        300,
        400
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "OsRBfz3Cs7Ph5uV5",
          "name": "Google Calendar account"
        }
      },
      "onError": "continueErrorOutput",
      "id": "cbe5309c-d954-4182-a934-7a90422e0f34"
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first()?.json || {};\nconst isError = !!result.error;\n\nreturn [{\n  json: {\n    success: !isError,\n    error_code: isError ? 'GCAL_DELETE_ERROR' : null,\n    error_message: isError ? (result.error?.message || 'Failed to delete GCal event') : null,\n    data: isError ? null : { deleted: true },\n    _meta: {\n      source: 'GCAL_Delete_Event',\n      timestamp: new Date().toISOString(),\n      workflow_id: 'GCAL_Delete_Event',\n      version: '1.1.0'\n    }\n  }\n}];"
      },
      "name": "Format Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        550,
        400
      ],
      "id": "dc4555f8-a8a4-4465-81ce-9e666c059d69"
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
