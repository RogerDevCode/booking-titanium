            "index": 0
          }
        ],
        [
          {
            "node": "Format Output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "description": "Elimina un evento previamente agendado de Google Calendar.",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": true
  }
